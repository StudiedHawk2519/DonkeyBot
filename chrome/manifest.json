{
    "manifest_version": 3,
    "name": "DonkeyBot",
    "version": "1.1",
    "description": "DonkeyBot - Homework Helper. Includes LanguageNot and Decade.",
    "permissions": [
        "storage",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "assets/icon.svg"
    },
    "icons": {
        "16": "assets/icon.svg",
        "48": "assets/icon.svg",
        "128": "assets/icon.svg"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.languagenut.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://*.century.tech/*"
            ],
            "js": [
                "decade.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "inject.js",
                "decade_inject.js",
                "assets/icon.svg"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}